		image: 'https://images.unsplash.com/photo-1511578314322-379afb476865?auto=format&fit=crop&w=900&q=80',
		link: '#social',
	},
	{
		tag: 'Comunity',
		title: 'Fondazioni, scuole e sport: un’agenda locale chiara',
		description: 'Card editoriali snelle, visual forti e CTA leggibili su mobile senza disperdere attenzione.',
		image: 'https://images.unsplash.com/photo-1515169067868-5387ec356754?auto=format&fit=crop&w=900&q=80',
		link: '#palinsesto',
	},
	{
		tag: 'On demand',
		title: 'Ogni rubrica diventa clip, podcast e short social',
		description: 'Una homepage pensata per spingere ascolto live e contenuti riutilizzabili su piu canali.',
		image: 'https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?auto=format&fit=crop&w=900&q=80',
		link: '#podcast',
	},
];

const podcasts = [
	{
		meta: 'Nuovo episodio',
		title: 'Cronache di Langa',
		description: 'Racconti brevi, cultura e imprenditoria di Alba e dintorni in formato seriale.',
		audio: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3',
	},
	{
		meta: 'Talk',
		title: 'Microfono Aperto Piemonte',
		description: 'Dialoghi piu strutturati con amministratori, comunicatori e operatori del territorio.',
		audio: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3',
	},
	{
		meta: 'Speciale',
		title: 'Dentro il Festival',
		description: 'Backstage, clip verticali e recap audio di eventi locali con montaggio piu contemporaneo.',
		audio: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3',
	},
];

const gallery = [
	{
		className: 'gallery-card gallery-card--tall',
		image: 'https://images.unsplash.com/photo-1501386761578-eac5c94b800a?auto=format&fit=crop&w=900&q=80',
		title: 'Festival e piazze vive',
		description: 'La radio come presidio culturale sul territorio.',
	},
	{
		className: 'gallery-card gallery-card--wide',
		image: 'https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?auto=format&fit=crop&w=1200&q=80',
		title: 'Studio visuale e social-ready',
		description: 'Setup pensato per live, clip e contenuti sponsorizzabili.',
	},
	{
		className: 'gallery-card',
		image: 'https://images.unsplash.com/photo-1516280440614-37939bbacd81?auto=format&fit=crop&w=900&q=80',
		title: 'Voce e community',
		description: 'Interazione diretta con ascoltatori e partner locali.',
	},
	{
		className: 'gallery-card',
		image: 'https://images.unsplash.com/photo-1511379938547-c1f69419868d?auto=format&fit=crop&w=900&q=80',
		title: 'Brand activation',
		description: 'Spazi sponsor integrati con una resa premium.',
	},
];

const topTracks = [
	{
		rank: '01',
		title: 'Sotto i Portici',
		artist: 'Marta Vento',
		description: 'Pop raffinato, ritmica contemporanea e un immaginario fortemente piemontese.',
	},
	{
		rank: '02',
		title: 'Corsa in Corso Europa',
		artist: 'Neve Chiara',
		description: 'Brano radiofonico pensato per drive time, hook immediato e produzione pulita.',
	},
	{
		rank: '03',
		title: 'Langhe Neon',
		artist: 'I Collinari',
		description: 'Synth-pop locale per una playlist che suona moderna senza perdere radici.',
	},
];

const sponsors = [
	{
		title: 'Partner premium',
		description: 'Formati high-impact per concessionarie, eventi, food e realta storiche del territorio.',
		image: 'https://images.unsplash.com/photo-1489515217757-5fd1be406fef?auto=format&fit=crop&w=1200&q=80',
	},
	{
		title: 'Spazi branded',
		description: 'Banner, clip, segmenti audio e storytelling sponsor in un’unica UX coerente.',
		image: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=900&q=80',
	},
	{
		title: 'Distribuzione smart',
		description: 'Homepage modulare, contenuti live e repack automatico per social e podcast.',
		image: 'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?auto=format&fit=crop&w=900&q=80',
	},
];

const socialCards = [
	{
		title: 'Instagram & Facebook',
		description: 'Stories, backstage e copertura eventi con grafiche coordinate.',
		image: 'https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=900&q=80',
		cta: 'Apri profili',
	},
	{
		title: 'YouTube & Shorts',
		description: 'Interviste video, rubriche e format brevi pensati per distribuzione continua.',
		image: 'https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?auto=format&fit=crop&w=900&q=80',
		cta: 'Guarda i video',
	},
	{
		title: 'WhatsApp community',
		description: 'Alert live, palinsesto e notizie utility inviate con tono editoriale.',
		image: 'https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=900&q=80',
		cta: 'Entra nel canale',
	},
];

const features = [
	{
		title: 'Player persistente',
		description: 'Ascolto live sempre disponibile con barra fissa, stato visivo e fallback rapido.',
	},
	{
		title: 'Homepage editoriale',
		description: 'La gerarchia dei contenuti privilegia live, programmi, sponsor e on demand.',
	},
	{
		title: 'Mobile-first reale',
		description: 'CTA leggibili, moduli grandi, layout chiaro e interazione immediata da smartphone.',
	},
];

const manifesto = [
	{
		title: 'Territorio, non template',
		description: 'Linguaggio visivo caldo, autorevole e con richiami a vino, piazze, colline e cultura locale.',
	},
	{
		title: 'Più conversione',
		description: 'Le CTA principali portano a tre azioni utili: ascoltare, scoprire il palinsesto, attivare partnership.',
	},
	{
		title: 'Pronto a crescere',
		description: 'Il progetto puo evolvere in CMS, podcast hub, app o membership senza dover rifare la UI.',
	},
];

const streamUrl = 'https://stream.live.vc.bbcmedia.co.uk/bbc_radio_one';
---

<Layout
	title="Radio Alba | Demo moderna in Astro"
	description="Demo moderna per Radio Alba: live player, palinsesto, podcast, sponsor e UI editoriale pensata per il territorio piemontese."
>
	<div class="page-shell">
		<div class="page-content">
			<header class="topbar" id="topbar" data-open="false">
				<a class="brand" href="#home" aria-label="Vai alla home Radio Alba">
					<div class="brand-mark">RA</div>
					<div class="brand-copy">
						<strong>Radio Alba</strong>
						<span>Digitale piu pulito, voce piu forte sul territorio.</span>
					</div>
				</a>

				<nav class="nav-links" aria-label="Navigazione principale">
					<a href="/palinsesto">Palinsesto</a>
					<a href="#interviste">Video</a>
					<a href="#podcast">Podcast</a>
					<a href="#gallery">Scene</a>
					<a href="/playlist">Social</a>
				</nav>

				<div class="topbar-actions">
					<span class="live-pill">In onda</span>
					<a class="cta" href="#player">Ascolta live</a>
				</div>

				<button class="mobile-menu" id="menuToggle" type="button" aria-expanded="false" aria-controls="topbar">
					<span class="sr-only">Apri menu</span>
					☰
				</button>
			</header>

			<main id="home" class="surface hero">
				<div class="hero-grid">
					<div class="hero-copy">
						<div>
							<span class="eyebrow">Restyle rapido</span>
							<h1 class="hero-title">Meno vetrina, piu ritmo editoriale.</h1>
							<p>
								Ho reimpostato la pagina con un tono piu netto: tipografia sans piu contemporanea, sezioni piu aperte,
								meno card decorative e una lettura piu lineare per una radio locale che vuole sembrare davvero attiva.
							</p>
						</div>

						<div class="hero-actions">
							<a class="cta" href="#player">Avvia player</a>
							<a class="cta-secondary" href="/palinsesto">Vedi programmi</a>
							<a class="chip-button" href="#contatti">Contatti commerciali</a>
						</div>

						<div class="hero-stats">
							<div class="stat-line">
								<strong>Live</strong>
								<span>Subito accessibile e sempre visibile.</span>
							</div>
							<div class="stat-line">
								<strong>Local</strong>
								<span>Palinsesto, volti e sponsor del territorio.</span>
							</div>
							<div class="stat-line">
								<strong>Clean</strong>
								<span>Gerarchia piu chiara su desktop e mobile.</span>
							</div>
						</div>

						<div class="hero-meta">
							<span class="tag">Alba</span>
							<span class="tag">Langhe</span>
							<span class="tag">Community</span>
							<span class="tag">Audio + video</span>
						</div>
					</div>

					<div class="hero-side">
						<div class="hero-panel">
							<div class="now-line">
								<div>
									<div class="kicker">Adesso in onda</div>
									<h2>Langhe Drive</h2>
									<p class="muted">Notizie, viabilita, eventi e una scaletta piu fresca per il rientro.</p>
								</div>
								<div class="equalizer" aria-hidden="true">
									<span></span><span></span><span></span><span></span>
								</div>
							</div>

							<ul class="compact-list">
								<li>
									<strong>18:00</strong>
									<span>Flash eventi tra Alba, Bra e Roero</span>
								</li>
								<li>
									<strong>18:15</strong>
									<span>Ospite locale in studio</span>
								</li>
								<li>
									<strong>18:30</strong>
									<span>Top rotation e community update</span>
								</li>
							</ul>

							<div class="audio-hint">
								<a class="cta-secondary" href="#podcast">Riascolta i podcast</a>
								<a class="chip-button" href="#social">Guarda i video</a>
							</div>
						</div>

						<figure class="hero-image">
							<img
								src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?auto=format&fit=crop&w=1200&q=80"
								alt="Studio radio moderno con energia live"
							/>
							<figcaption>
								<strong style="display:block; margin-bottom:6px; font-size:1.15rem;">Una home piu ariosa e meno decorativa.</strong>
								<span>Il focus torna su lettura, ritmo e contenuti davvero utili.</span>
							</figcaption>
						</figure>
					</div>
				</div>
			</main>

			<section class="surface section">
				<div class="section-heading">
					<div>
						<span class="eyebrow">Direzione visiva</span>
						<h2>Una radio di Alba puo sembrare attuale senza perdere territorio.</h2>
					</div>
					<p>Palette piu chiara, accenti terracotta, font sans piu caratterizzato e molto meno peso visivo inutile.</p>
				</div>
				<div class="manifest-grid">
					{manifesto.map((item) => (
						<article class="manifest-card">
							<span class="kicker">Concept</span>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</article>
					))}
				</div>
			</section>

			<section class="surface section split-layout" id="palinsesto" aria-labelledby="palinsesto-title">
				<div class="split-copy">
					<span class="eyebrow">Palinsesto</span>
					<h2 id="palinsesto-title">Impaginazione piu editoriale, non griglia anonima.</h2>
					<p>
						Ho messo un blocco guida a sinistra e i programmi a destra, cosi il palinsesto ha un ingresso chiaro e non
						sembra una sequenza infinita di riquadri tutti uguali.
					</p>
				</div>
				<div class="schedule-col">
					<div class="schedule-lead">
						<div class="kicker">Fascia chiave</div>
						<h3>Il drive time diventa il centro della homepage.</h3>
						<p>
							Il blocco principale introduce la giornata, mentre le altre trasmissioni seguono con una densita visiva piu leggera.
						</p>
						<a class="cta" href="#player">Ascolta il live</a>
					</div>
					<div class="shows-grid">
						{shows.map((show) => (
							<article class="show-card">
								<div class="show-meta">
									<time>{show.time}</time>
									<span>{show.host}</span>
								</div>
								<h3>{show.title}</h3>
								<p>{show.description}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="surface section split-layout" id="interviste" aria-labelledby="interviste-title">
				<div class="split-copy">
					<span class="eyebrow">Video e rubriche</span>
					<h2 id="interviste-title">Le interviste respirano di piu e sembrano contenuti, non box promozionali.</h2>
					<p>Uso immagine grande, titoli piu netti e descrizioni corte. Il colpo d'occhio adesso e molto piu immediato.</p>
				</div>
				<div class="interview-grid">
					{interviews.map((item) => (
						<a class="interview-card" href={item.link}>
							<img src={item.image} alt={item.title} loading="lazy" />
							<span class="tag">{item.tag}</span>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="surface section split-layout" id="podcast" aria-labelledby="podcast-title">
				<div class="split-copy">
					<span class="eyebrow">Podcast</span>
					<h2 id="podcast-title">Audio on demand con blocchi piu puliti.</h2>
					<p>Stesso contenuto, ma con gerarchia migliore: prima il titolo, poi il senso del format, poi il player.</p>
				</div>
				<div class="podcast-grid">
					{podcasts.map((podcast) => (
						<article class="podcast-card">
							<span class="tag">{podcast.meta}</span>
							<h3>{podcast.title}</h3>
							<p>{podcast.description}</p>
							<audio class="podcast-player" controls preload="none">
								<source src={podcast.audio} type="audio/mpeg" />
							</audio>
						</article>
					))}
				</div>
			</section>

			<section class="gallery-stage surface" id="gallery" aria-labelledby="gallery-title">
				<div class="gallery-stage-header">
					<div>
						<span class="eyebrow" style="color: var(--accent-soft);">Scene</span>
						<h2 id="gallery-title" class="gallery-stage-title">Radio Alba fuori dal microfono.</h2>
					</div>
					<p class="gallery-stage-sub">Festival, studio, piazze, community. Impressioni dal vivo.</p>
				</div>

				<div class="polaroid-stage">
					<!-- Hero polaroid -->
					<figure class="polaroid polaroid--hero" aria-label={gallery[0].title}>
						<div class="polaroid-photo">
							<img src={gallery[0].image} alt={gallery[0].title} loading="lazy" />
						</div>
						<figcaption class="polaroid-caption">{gallery[0].title}</figcaption>
					</figure>

					<!-- Scatter cluster -->
					<div class="polaroid-cluster">
						<figure class="polaroid polaroid--a" aria-label={gallery[1].title}>
							<div class="polaroid-photo">
								<img src={gallery[1].image} alt={gallery[1].title} loading="lazy" />
							</div>
							<figcaption class="polaroid-caption">{gallery[1].title}</figcaption>
						</figure>
						<figure class="polaroid polaroid--b" aria-label={gallery[2].title}>
							<div class="polaroid-photo">
								<img src={gallery[2].image} alt={gallery[2].title} loading="lazy" />
							</div>
							<figcaption class="polaroid-caption">{gallery[2].title}</figcaption>
						</figure>
						<figure class="polaroid polaroid--c" aria-label={gallery[3].title}>
							<div class="polaroid-photo">
								<img src={gallery[3].image} alt={gallery[3].title} loading="lazy" />
							</div>
							<figcaption class="polaroid-caption">{gallery[3].title}</figcaption>
						</figure>
					</div>
				</div>

				<p class="gallery-stage-note">{gallery[0].description} · {gallery[1].description}</p>
			</section>

			<section class="surface section">
				<div class="section-heading">
					<div>
						<span class="eyebrow">Partner locali</span>
						<h2>Gli sponsor tornano evidenti, ma con piu controllo visivo.</h2>
					</div>
					<p>Ho lasciato l'idea dei grandi visual sponsor, ma in una composizione piu ordinata e meno pesante.</p>
				</div>
				<div class="partner-grid">
					<article class="sponsor-banner sponsor-banner--large">
						<img src={sponsors[0].image} alt={sponsors[0].title} loading="lazy" />
						<div class="banner-copy">
							<span class="tag" style="color:#fff1e8;">Partner premium</span>
							<h3 style="margin:10px 0 8px; font-family:'Syne', sans-serif; font-size:1.6rem; line-height:1.02;">{sponsors[0].title}</h3>
							<p style="margin:0;">{sponsors[0].description}</p>
						</div>
					</article>
					{sponsors.slice(1).map((item) => (
						<article class="sponsor-banner">
							<img src={item.image} alt={item.title} loading="lazy" />
							<div class="banner-copy">
								<span class="tag" style="color:#fff1e8;">Adv layout</span>
								<h3 style="margin:10px 0 8px; font-family:'Syne', sans-serif; font-size:1.25rem; line-height:1.02;">{item.title}</h3>
								<p style="margin:0;">{item.description}</p>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="surface brand-close" id="social" aria-labelledby="brand-close-title">
				<div class="bc-chart">
					<div class="bc-chart-header">
						<div>
							<span class="eyebrow">Playlist</span>
							<h2 id="brand-close-title" class="bc-chart-title">Top 3 questa settimana</h2>
						</div>
						<a class="chip-button" href="/playlist">Vedi tutto</a>
					</div>
					<ol class="bc-tracks" aria-label="Classifica settimanale">
						{topTracks.map((track, i) => (
							<li class="bc-track" style={`--i: ${i}`}>
								<span class="bc-rank" aria-hidden="true">{track.rank}</span>
								<div class="bc-track-body">
									<span class="bc-artist">{track.artist}</span>
									<strong class="bc-title">{track.title}</strong>
									<p class="bc-desc">{track.description}</p>
								</div>
							</li>
						))}
					</ol>
				</div>

				<div class="bc-social">
					<p class="bc-social-label eyebrow" style="color: var(--accent-soft);">Seguici</p>
					{socialCards.map((item) => (
						<a class="bc-social-link" href="#">
							<span class="bc-social-name">{item.title}</span>
							<span class="bc-social-cta">{item.cta} →</span>
						</a>
					))}
				</div>
			</section>

			<footer class="surface section" id="contatti">
				<div class="footer-grid">
					<div>
						<div class="footer-brand">Radio Alba</div>
						<p class="muted" style="max-width: 44ch; margin-top: 12px;">
							Restyle demo con nuova tipografia e una struttura molto piu ordinata, pensata per far percepire meglio contenuti e identita.
						</p>
					</div>
					<div class="footer-contact">
						<a href="tel:+390173280471">+39 0173 280471</a>
						<a href="tel:+393347834975">+39 334 7834975</a>
						<a href="mailto:info@radioalba.it">info@radioalba.it</a>
						<a href="https://www.radioalba.it">radioalba.it</a>
					</div>
					<div class="footer-note">
						Radio Alba srl<br />
						C.so Europa 61, Alba<br />
						P.IVA 03626990042<br />
						<a href="#home">Torna in alto</a>
					</div>
				</div>
			</footer>
		</div>
	</div>

	<div class="player-bar" id="player">
		<button class="player-toggle" id="playerToggle" type="button" aria-pressed="false">Play</button>
		<div class="player-meta">
			<div class="player-cover">RA</div>
			<div>
				<strong>Radio Alba Live</strong>
				<div class="player-status" id="playerStatus">Premi play per provare il live stream demo.</div>
			</div>
		</div>
		<div class="player-wave" aria-hidden="true">
			<span></span><span></span><span></span><span></span>
		</div>
		<a class="cta-secondary player-link" href={streamUrl} target="_blank" rel="noreferrer">Apri stream</a>
		<audio id="radioStream" preload="none">
			<source src={streamUrl} type="audio/mpeg" />
		</audio>
	</div>

	<script is:inline>
		const topbar = document.getElementById('topbar');
		const menuToggle = document.getElementById('menuToggle');
		const playerToggle = document.getElementById('playerToggle');
		const playerStatus = document.getElementById('playerStatus');
		const radioStream = document.getElementById('radioStream');

		menuToggle?.addEventListener('click', () => {
			const isOpen = topbar?.getAttribute('data-open') === 'true';
			topbar?.setAttribute('data-open', String(!isOpen));
			menuToggle.setAttribute('aria-expanded', String(!isOpen));
		});

		const setPlayerState = (isPlaying, message) => {
			if (!playerToggle || !playerStatus) return;
			playerToggle.textContent = isPlaying ? 'Pause' : 'Play';
			playerToggle.setAttribute('aria-pressed', String(isPlaying));
			playerStatus.textContent = message;
		};

		playerToggle?.addEventListener('click', async () => {
			if (!(radioStream instanceof HTMLAudioElement)) return;

			if (radioStream.paused) {
				try {
					await radioStream.play();
					setPlayerState(true, 'Streaming live attivo. Se il browser blocca l’audio, usa il link esterno.');
				} catch (error) {
					setPlayerState(false, 'Il live puo richiedere conferma del browser. Usa anche il link Apri stream.');
				}
			} else {
				radioStream.pause();
				setPlayerState(false, 'Live in pausa. Premi play per riprendere.');
			}
		});

		radioStream?.addEventListener('ended', () => {
			setPlayerState(false, 'La sessione live e terminata. Premi play per riattivarla.');
		});
	</script>
</Layout>
